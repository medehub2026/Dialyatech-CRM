generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  CRM_ADMIN
  MARKETING_MANAGER
  SALES_EXECUTIVE
  SUPPORT_EXECUTIVE
}

enum UserStatus {
  ACTIVE
  BLOCKED
  INVITED
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  KYC_PENDING
  APPROVED
  REJECTED
  NEGOTIATION
  CONVERTED
  LOST
  BLOCKED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  HOT
}

model User {
  id           String      @id @default(cuid())
  name         String
  email        String      @unique
  phone        String?
  passwordHash String
  role         UserRole    @default(SALES_EXECUTIVE)
  status       UserStatus  @default(ACTIVE)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  teamMember   TeamMember?
}

model PharmacyLead {
  id                    String     @id @default(cuid())
  pharmacyName          String
  ownerName             String
  mobile                String     @unique
  whatsappNumber        String?
  email                 String?
  city                  String
  area                  String
  address               String?
  pincode               String?
  drugLicenseNumber     String?
  drugLicenseStatus     String     @default("Pending")
  gstNumber             String?
  gstStatus             String     @default("Pending")
  currentBusinessType   String?
  monthlyOrderPotential Decimal?   @db.Decimal(12, 2)
  onboardingStage       String     @default("New")
  leadSource            String?
  leadPriority          Priority   @default(MEDIUM)
  assignedTo            String?
  nextFollowUpDate      DateTime?
  remarks               String?
  status                LeadStatus @default(NEW)
  blocked               Boolean    @default(false)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
}

model DeliveryPartnerLead {
  id                       String     @id @default(cuid())
  fullName                 String
  mobile                   String     @unique
  whatsappNumber           String?
  city                     String
  area                     String
  address                  String?
  vehicleType              String?
  vehicleNumber            String?
  drivingLicenseNumber     String?
  drivingLicenseStatus     String     @default("Pending")
  aadhaarStatus            String     @default("Pending")
  policeVerificationStatus String     @default("Not Started")
  trainingStatus           String     @default("Not Started")
  preferredWorkingTime     String?
  onboardingStage          String     @default("New")
  assignedTo               String?
  nextFollowUpDate         DateTime?
  remarks                  String?
  status                   LeadStatus @default(NEW)
  blocked                  Boolean    @default(false)
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt
}

model B2BCustomerLead {
  id                      String     @id @default(cuid())
  businessName            String
  contactPerson           String
  mobile                  String     @unique
  whatsappNumber          String?
  email                   String?
  businessType            String
  city                    String
  area                    String
  address                 String?
  requirementType         String?
  expectedMonthlyPurchase Decimal?   @db.Decimal(12, 2)
  dealValue               Decimal?   @db.Decimal(12, 2)
  quotationStatus         String     @default("Not Sent")
  negotiationStage        String     @default("New")
  leadSource              String?
  assignedTo              String?
  nextFollowUpDate        DateTime?
  remarks                 String?
  status                  LeadStatus @default(NEW)
  blocked                 Boolean    @default(false)
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt
}

model FollowUpTask {
  id          String    @id @default(cuid())
  leadType    String
  leadId      String
  title       String
  description String?
  assignedTo  String?
  dueDate     DateTime
  priority    Priority  @default(MEDIUM)
  status      String    @default("Open")
  completedAt DateTime?
  createdAt   DateTime  @default(now())
}

model ActivityLog {
  id          String   @id @default(cuid())
  leadType    String
  leadId      String
  actionType  String
  description String
  performedBy String?
  createdAt   DateTime @default(now())
}

model WhatsAppMessage {
  id                String    @id @default(cuid())
  leadType          String
  leadId            String
  phone             String
  templateName      String
  messageBody       String?
  status            String    @default("Sent")
  interaktMessageId String?
  sentBy            String?
  sentAt            DateTime  @default(now())
  deliveredAt       DateTime?
  readAt            DateTime?
  repliedAt         DateTime?
}

model Campaign {
  id              String   @id @default(cuid())
  name            String
  audienceType    String
  city            String?
  area            String?
  leadStatus      String?
  templateName    String
  scheduledAt     DateTime?
  campaignGoal    String?
  remarks         String?
  status          String   @default("Draft")
  sentCount       Int      @default(0)
  deliveredCount  Int      @default(0)
  readCount       Int      @default(0)
  replyCount      Int      @default(0)
  conversionCount Int      @default(0)
  createdBy       String?
  createdAt       DateTime @default(now())
}

model TeamMember {
  id                 String @id @default(cuid())
  userId             String @unique
  user               User   @relation(fields: [userId], references: [id])
  targetLeads        Int    @default(0)
  assignedLeads      Int    @default(0)
  callsDone          Int    @default(0)
  whatsappSent       Int    @default(0)
  followupsCompleted Int    @default(0)
  conversions        Int    @default(0)
  performanceScore   Int    @default(0)
}
